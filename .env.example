APP_NAME=BakiMate
APP_ENV=local
APP_KEY=
APP_DEBUG=true
# Use the same host:port the Expo app calls (see EXPO_PUBLIC_API_URL in bakimate/.env).
# `php artisan serve` → http://127.0.0.1:8000 — from a phone, use --host=0.0.0.0 and your LAN IP.
APP_URL=http://127.0.0.1:8000

# -----------------------------------------------------------------------------
# Production (Railway) — copy these into Railway → Service → Variables
# -----------------------------------------------------------------------------
# APP_ENV=production
# APP_DEBUG=false
# APP_URL=https://bakimate.habimate.com
# APP_KEY=base64:...   # generate with: php artisan key:generate --show
#
# CORS — comma-separated list of allowed browser origins. Mobile clients don't
# send an Origin header, so this only matters for browser callers (e.g. the
# public /v/{token} balance link). Leave as `*` until you ship a web UI.
# CORS_ALLOWED_ORIGINS=https://bakimate.habimate.com
#
# Trust the Railway edge proxy so HTTPS-aware redirects/signed URLs work.
# TRUSTED_PROXIES=*

# Demo login — POST /api/auth/demo. If DEMO_LOGIN_ENABLED is unset: on only when APP_ENV=local.
# DEMO_LOGIN_ENABLED=false
# DEMO_LOGIN_ENABLED=true

# Google id_token audience(s): list every OAuth client whose tokens you accept (id_token claim "aud").
# Option A — one CSV list:
# GOOGLE_CLIENT_IDS=id-ios.apps.googleusercontent.com,id-android.apps.googleusercontent.com,id-web.apps.googleusercontent.com
#
# Option B — same names as Expo (bakimate/.env EXPO_PUBLIC_GOOGLE_* — copy values only, paste here without EXPO_PUBLIC_):
# GOOGLE_IOS_CLIENT_ID=
# GOOGLE_ANDROID_CLIENT_ID=
# GOOGLE_WEB_CLIENT_ID=
# GOOGLE_EXPO_CLIENT_ID=
# GOOGLE_CLIENT_ID=
#
# You can mix A + B; duplicates are ignored. Expo Go proxy typically uses WEB (or EXPO) client aud.
#
# Apple Sign in with Apple — JWT "aud" usually matches the iOS bundle ID (and/or a Services ID if you add web).
# APPLE_CLIENT_IDS=com.ihabimate.bakimate
# APPLE_CLIENT_ID=com.ihabimate.bakimate
#
# Gemini (Google AI Studio) — enables POST /api/receipt-scan for snap-to-khata — same stack as Habimate.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug
# Production (Railway): use the platform's stdout log driver.
# LOG_CHANNEL=stderr
# LOG_LEVEL=info

# MySQL — create the database first, then run migrations.
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=bakimate
DB_USERNAME=root
DB_PASSWORD=

# MAMP often uses MySQL on port 8889 — set DB_PORT (and DB_SOCKET if needed).
# DB_SOCKET=/Applications/MAMP/tmp/mysql/mysql.sock

# Railway MySQL plugin — use the reference variables Railway exposes when you
# add the MySQL plugin to the project (they auto-update on rotation):
#
# DB_CONNECTION=mysql
# DB_HOST=${{MySQL.MYSQLHOST}}
# DB_PORT=${{MySQL.MYSQLPORT}}
# DB_DATABASE=${{MySQL.MYSQLDATABASE}}
# DB_USERNAME=${{MySQL.MYSQLUSER}}
# DB_PASSWORD=${{MySQL.MYSQLPASSWORD}}

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=database

CACHE_STORE=database
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# Local: keep log. Production: reuse Habimate Mailgun vars until BakiMate has its own sender/domain.
MAIL_MAILER=log
# MAIL_MAILER=mailgun
# MAILGUN_DOMAIN=mg.your-habimate-domain.com
# MAILGUN_SECRET=key-your-mailgun-private-api-key
# MAILGUN_ENDPOINT=api.mailgun.net
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Password reset emails use a deep link so the mobile app can open the reset screen.
# Must match Expo `scheme` in app.json (default: bakimate) and the route `reset-password`.
# PASSWORD_RESET_APP_SCHEME=bakimate
# PASSWORD_RESET_APP_PATH=reset-password

# After the user taps Verify in the email, the browser opens this URL, then the app (Expo scheme + verify-email).
# EMAIL_VERIFIED_REDIRECT_URL=bakimate://verify-email?verified=1
# EMAIL_VERIFICATION_EXPIRE_MINUTES=60

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"
